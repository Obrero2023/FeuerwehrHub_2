# ═══════════════════════════════════════════════════════════════
#  FeuerwehrHub — Konfiguration
#  Kopiere diese Datei nach .env und passe die Werte an.
# ═══════════════════════════════════════════════════════════════

# ── Betriebsmodus ───────────────────────────────────────────────
#
#  A) Standalone (PostgreSQL inklusive) — empfohlen für Einsteiger:
#     docker compose --profile standalone up -d
#     → DB_HOST und DB_PORT können auf Standard belassen werden.
#
#  B) Externe Datenbank (eigener PostgreSQL-Server):
#     docker compose up -d
#     → DB_HOST auf die IP/den Hostname deines Servers setzen.
#
#  C) Lokale Entwicklung (Backend außerhalb Docker, DB in Docker):
#     DB_HOST=localhost (wenn DB in Docker mit Port 5432:5432 läuft)
#
# ───────────────────────────────────────────────────────────────

# ── Datenbank ───────────────────────────────────────────────────
# Modus A (standalone): Werte so lassen, DB_HOST=postgres
# Modus B (extern):     DB_HOST auf deinen Server zeigen lassen
# Modus C (lokal):      DB_HOST=localhost
DB_HOST=postgres
DB_PORT=5432
DB_NAME=feuerwehrhub
DB_USER=feuerwehrhub
DB_PASSWORD=sicheres-passwort-aendern

# ── Backend ─────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=3000

# JWT — Pflichtfeld, mind. 32 Zeichen, kein Default!
# Generieren:
#   Linux/Mac/WSL:      openssl rand -hex 64
#   Windows PowerShell: -join ((1..64) | ForEach-Object { '{0:x2}' -f (Get-Random -Max 256) })
#   Online:             https://www.uuidgenerator.net/
# Der Server startet NICHT wenn dieser Wert zu kurz ist oder dem Default entspricht.
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRY_HOURS=8

# Verschlüsselungs-Key (AES-256) — MUSS sich von JWT_SECRET unterscheiden!
# Generieren: openssl rand -hex 64
# Wenn nicht gesetzt: JWT_SECRET wird als Fallback genutzt (nicht empfohlen).
# ACHTUNG: Änderung macht bestehende TOTP-Secrets unlesbar → Nutzer müssen 2FA neu einrichten.
ENCRYPTION_KEY=change-this-to-a-different-random-secret

# ── Feuerwehr ───────────────────────────────────────────────────
FF_NAME=Freiwillige Feuerwehr Musterstadt

# ── Sicherheit ──────────────────────────────────────────────────
# FRONTEND_URL muss exakt der Origin des Frontends entsprechen (kein trailing slash, kein non-standard Port)
# Produktion Beispiel: https://feuerwehr.example.com
FRONTEND_URL=http://localhost
LOGIN_MAX_ATTEMPTS=5
LOCKOUT_MINUTES=15

# ── Updates ─────────────────────────────────────────────────────
# Neue Version verfügbar? Images ziehen und neu starten:
#   docker compose pull && docker compose up -d
# Migrationen laufen automatisch beim Start durch.
# Neue Versionen: https://github.com/obrero2023/FeuerwehrHub_2/releases
